{
  "name": "ledger",
  "version": "1.0.0",
  "description": "",
  "main": "index.js",
  "scripts": {
    "dev": "tsx src/infra/dev/run-dev.ts",
    "start": "node dist/index.js",
    "build": "tsc",
    "test": "vitest run",
    "test:watch": "vitest",
    "audit": "npx tsx src/infra/tools/read-audit.ts",
    "test:coverage": "vitest run --coverage",
    "typeorm": "node --require tsx/cjs ./node_modules/typeorm/cli.js",
    "db:migration:generate": "npm run typeorm -- migration:generate src/infra/database/migrations/Migration -d src/infra/database/data-source.ts",
    "db:migration:run": "npm run typeorm -- migration:run -d src/infra/database/data-source.ts",
    "db:migration:revert": "npm run typeorm -- migration:revert -d src/infra/database/data-source.ts"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "type": "commonjs",
  "dependencies": {
    "dotenv": "^17.4.2",
    "express": "^4.18.2",
    "mongodb": "^6.21.0",
    "pg": "^8.20.0",
    "reflect-metadata": "^0.2.2",
    "typeorm": "^0.3.28",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/express": "^4.17.21",
    "@types/node": "^25.3.3",
    "@types/pg": "^8.20.0",
    "@vitest/coverage-v8": "^4.1.0",
    "tsx": "^4.21.0",
    "typescript": "^5.4.5",
    "vitest": "^4.1.0"
  }
}
